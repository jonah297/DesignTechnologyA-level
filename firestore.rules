rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function emailId() {
      return request.auth.token.email.lower();
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function licensePath(licenseId) {
      return /databases/$(database)/documents/licenses/$(licenseId);
    }

    function accessCodePath(codeId) {
      return /databases/$(database)/documents/teacher_access_codes/$(codeId);
    }

    function assignmentPath(assignmentId) {
      return /databases/$(database)/documents/assignments/$(assignmentId);
    }

    function classInvitePath(inviteId) {
      return /databases/$(database)/documents/class_invites/$(inviteId);
    }

    function classJoinCodePath(codeId) {
      return /databases/$(database)/documents/class_join_codes/$(codeId);
    }

    function studentApprovalPath(licenseId, studentId) {
      return /databases/$(database)/documents/licenses/$(licenseId)/approved_students/$(studentId);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath(emailId()));
    }

    function hasUserDocAfter() {
      return signedIn() && existsAfter(userPath(emailId()));
    }

    function userData() {
      return get(userPath(emailId())).data;
    }

    function userDataAfter() {
      return getAfter(userPath(emailId())).data;
    }

    function isOwner(userId) {
      return signedIn() && userId == emailId();
    }

    function hasRole(role) {
      return hasUserDoc() && userData().role == role;
    }

    function hasRoleAfter(role) {
      return hasUserDocAfter() && userDataAfter().role == role;
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isTeacher() {
      return hasRole("teacher");
    }

    function isTeacherOrAdmin() {
      return isTeacher() || isAdmin();
    }

    function listContains(listValue, target) {
      return listValue is list && target in listValue;
    }

    function userClassIds() {
      return hasUserDoc() && userData().classIds is list ? userData().classIds : [];
    }

    function profileInClass(profileData, classId) {
      return (profileData.classIds is list && classId in profileData.classIds)
        || profileData.classId == classId
        || profileData.classCode == classId;
    }

    function sharesAnyClass(profileData) {
      return hasUserDoc()
        && (
          (profileData.classIds is list && profileData.classIds.hasAny(userClassIds()))
          || listContains(userClassIds(), profileData.classId)
          || listContains(userClassIds(), profileData.classCode)
        );
    }

    function isClassMember(classId) {
      return hasUserDoc()
        && (
          listContains(userClassIds(), classId)
          || userData().classId == classId
          || userData().classCode == classId
        );
    }

    function licenseIsOpen(licenseData) {
      return !(
          licenseData.status in ["expired", "cancelled"]
          || (licenseData.trialEndsAt is timestamp && licenseData.trialEndsAt < request.time)
          || (licenseData.expiresAt is timestamp && licenseData.expiresAt < request.time)
        );
    }

    function licenseAllowsNewWork(licenseId) {
      return licenseId == null
        || licenseId == ""
        || !exists(licensePath(licenseId))
        || licenseIsOpen(get(licensePath(licenseId)).data);
    }

    function isLicenseMember(licenseId, licenseData) {
      return signedIn()
        && (
          isAdmin()
          || licenseData.ownerId == emailId()
          || listContains(licenseData.teacherIds, emailId())
          || listContains(licenseData.adminIds, emailId())
          || (hasUserDoc() && userData().licenseId == licenseId)
        );
    }

    function canManageLicense(licenseData) {
      return signedIn()
        && (
          isAdmin()
          || licenseData.ownerId == emailId()
          || listContains(licenseData.adminIds, emailId())
        );
    }

    function accessCodeData(codeId) {
      return get(accessCodePath(codeId)).data;
    }

    function classInviteData(inviteId) {
      return get(classInvitePath(inviteId)).data;
    }

    function classJoinCodeData(codeId) {
      return get(classJoinCodePath(codeId)).data;
    }

    function studentApprovalData(licenseId, studentId) {
      return get(studentApprovalPath(licenseId, studentId)).data;
    }

    function validClassJoinCode(codeId) {
      return signedIn()
        && codeId is string
        && exists(classJoinCodePath(codeId))
        && classJoinCodeData(codeId).status == "active"
        && classJoinCodeData(codeId).classId is string
        && classJoinCodeData(codeId).expiresAt is timestamp
        && classJoinCodeData(codeId).expiresAt > request.time;
    }

    function validStudentApprovalForLicense(licenseId) {
      return signedIn()
        && licenseId is string
        && exists(studentApprovalPath(licenseId, emailId()))
        && studentApprovalData(licenseId, emailId()).email == emailId()
        && studentApprovalData(licenseId, emailId()).licenseId == licenseId
        && studentApprovalData(licenseId, emailId()).status in ["approved", "joined"];
    }

    function validTeacherAccessCode(codeId) {
      return signedIn()
        && codeId is string
        && exists(accessCodePath(codeId))
        && accessCodeData(codeId).status == "active"
        && accessCodeData(codeId).targetTeacherEmail == emailId()
        && (
          !(accessCodeData(codeId).expiresAt is timestamp)
          || accessCodeData(codeId).expiresAt > request.time
        );
    }

    function validTeacherClassInvite(inviteId) {
      return signedIn()
        && inviteId is string
        && exists(classInvitePath(inviteId))
        && classInviteData(inviteId).status == "pending"
        && classInviteData(inviteId).targetTeacherEmail == emailId()
        && classInviteData(inviteId).licenseId is string
        && request.resource.data.licenseId == classInviteData(inviteId).licenseId
        && request.resource.data.classIds is list
        && request.resource.data.classIds.size() == 0
        && request.resource.data.classes is list
        && request.resource.data.classes.size() == 0;
    }

    function classAccessFieldsChanged() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return changed.hasAny([
        "classCode",
        "classId",
        "classIds",
        "classes",
        "licenseId",
        "joinCodeId",
        "schoolName"
      ]);
    }

    function validSharedTeacherInviteClassAccessUpdate() {
      let inviteId = request.resource.data.lastAcceptedInviteId;
      return resource.data.role == "teacher"
        && resource.data.accountManager == false
        && inviteId is string
        && exists(classInvitePath(inviteId))
        && classInviteData(inviteId).status == "pending"
        && classInviteData(inviteId).targetTeacherEmail == emailId()
        && classInviteData(inviteId).licenseId is string
        && classInviteData(inviteId).classId is string
        && request.resource.data.licenseId == classInviteData(inviteId).licenseId
        && request.resource.data.classIds is list
        && resource.data.classIds is list
        && request.resource.data.classIds.hasAll(resource.data.classIds)
        && request.resource.data.classIds.hasAll([classInviteData(inviteId).classId])
        && request.resource.data.classIds.size() <= resource.data.classIds.size() + 1
        && request.resource.data.classes is list
        && request.resource.data.classes.size() == request.resource.data.classIds.size()
        && listContains(request.resource.data.classIds, request.resource.data.classCode)
        && request.resource.data.signupInviteId == resource.data.signupInviteId
        && request.resource.data.schoolName == resource.data.schoolName
        && request.resource.data.accountManager == resource.data.accountManager;
    }

    function ownerClassAccessUpdateAllowed() {
      return !classAccessFieldsChanged()
        || (
          resource.data.role == "teacher"
          && (
            resource.data.accountManager == true
            || validSharedTeacherInviteClassAccessUpdate()
          )
        )
        || (
          resource.data.role == "student"
          && validStudentJoinClassUpdate()
        );
    }

    function validStudentJoinClassUpdate() {
      let joinCodeId = request.resource.data.joinCodeId;
      let joinClassId = classJoinCodeData(joinCodeId).classId;
      let joinLicenseId = classJoinCodeData(joinCodeId).licenseId;
      return resource.data.role == "student"
        && request.resource.data.role == resource.data.role
        && validClassJoinCode(joinCodeId)
        && validStudentApprovalForLicense(joinLicenseId)
        && resource.data.classIds is list
        && request.resource.data.classIds is list
        && request.resource.data.classIds.hasAll(resource.data.classIds)
        && request.resource.data.classIds.hasAll([joinClassId])
        && request.resource.data.classIds.size() <= resource.data.classIds.size() + 1
        && request.resource.data.classCode is string
        && request.resource.data.classId == request.resource.data.classCode
        && listContains(request.resource.data.classIds, request.resource.data.classCode)
        && request.resource.data.licenseId == joinLicenseId
        && request.resource.data.schoolName == classJoinCodeData(joinCodeId).schoolName
        && request.resource.data.lastUpdated is int;
    }

    function classAccessAfterRemovalIsValid() {
      return request.resource.data.classIds is list
        && (
          (
            request.resource.data.classIds.size() == 0
            && request.resource.data.classCode == ""
            && request.resource.data.classId == ""
          )
          || (
            request.resource.data.classIds.size() > 0
            && request.resource.data.classCode is string
            && request.resource.data.classId == request.resource.data.classCode
            && listContains(request.resource.data.classIds, request.resource.data.classCode)
          )
        );
    }

    function validTeacherRemoveStudentFromClass(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let removedClassId = request.resource.data.removedFromClassId;
      return signedIn()
        && userId != emailId()
        && removedClassId is string
        && isTeacherForClass(removedClassId)
        && resource.data.role == "student"
        && request.resource.data.role == resource.data.role
        && resource.data.classIds is list
        && request.resource.data.classIds is list
        && listContains(resource.data.classIds, removedClassId)
        && !listContains(request.resource.data.classIds, removedClassId)
        && resource.data.classIds.hasAll(request.resource.data.classIds)
        && request.resource.data.classIds.size() <= resource.data.classIds.size()
        && classAccessAfterRemovalIsValid()
        && request.resource.data.removedBy == emailId()
        && request.resource.data.removedAt is int
        && request.resource.data.lastUpdated is int
        && changed.hasOnly([
          "classCode",
          "classId",
          "classIds",
          "removedFromClassId",
          "removedAt",
          "removedBy",
          "lastUpdated"
        ]);
    }

    function validTeacherPublicProfileClassRemoval(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && userId != emailId()
        && isTeacher()
        && existsAfter(userPath(userId))
        && resource.data.role == "student"
        && getAfter(userPath(userId)).data.role == "student"
        && request.resource.data.role == resource.data.role
        && resource.data.classIds is list
        && request.resource.data.classIds is list
        && resource.data.classIds.hasAny(userClassIds())
        && resource.data.classIds.hasAll(request.resource.data.classIds)
        && request.resource.data.classIds.size() <= resource.data.classIds.size()
        && request.resource.data.classIds == getAfter(userPath(userId)).data.classIds
        && request.resource.data.classId == getAfter(userPath(userId)).data.classCode
        && changed.hasOnly([
          "classId",
          "classIds",
          "updatedAt"
        ]);
    }

    function teacherCanCreatePilotLicense(licenseId) {
      let codeId = request.resource.data.createdFromAccessCodeId;
      let code = accessCodeData(codeId);
      return hasRoleAfter("teacher")
        && validTeacherAccessCode(codeId)
        && request.resource.data.status == "trial"
        && request.resource.data.ownerId == emailId()
        && (
          code.licenseId == null
          || code.licenseId == ""
          || code.licenseId == licenseId
        )
        && request.resource.data.teacherIds is list
        && request.resource.data.teacherIds.size() == 1
        && request.resource.data.teacherIds[0] == emailId()
        && request.resource.data.adminIds is list
        && request.resource.data.adminIds.size() == 0
        && code.maxClasses is int
        && code.maxSeatsPerClass is int
        && request.resource.data.max_classes <= code.maxClasses
        && request.resource.data.max_seats_per_class <= code.maxSeatsPerClass
        && request.resource.data.max_student_seats is int
        && request.resource.data.max_student_seats <= (
          code.maxStudentSeats is int
            ? code.maxStudentSeats
            : code.maxClasses * code.maxSeatsPerClass
        )
        && request.resource.data.trialStartsAt is timestamp
        && request.resource.data.trialEndsAt is timestamp;
    }

    function canReadAssignment(assignmentData) {
      return isAdmin()
        || (isTeacher() && assignmentData.teacherId == emailId())
        || isClassMember(assignmentData.classId);
    }

    function assignmentData(assignmentId) {
      return get(assignmentPath(assignmentId)).data;
    }

    function canReadUserProfile(userId, profileData) {
      return isOwner(userId)
        || isAdmin()
        || (isTeacher() && sharesAnyClass(profileData));
    }

    function canReadPublicProfile(userId, profileData) {
      return isOwner(userId)
        || isAdmin()
        || sharesAnyClass(profileData);
    }

    function canReadUserProgress(userId) {
      return isOwner(userId)
        || isAdmin()
        || (
          isTeacher()
          && exists(userPath(userId))
          && sharesAnyClass(get(userPath(userId)).data)
        );
    }

    function isTeacherForClass(classId) {
      return isTeacher() && isClassMember(classId);
    }

    function targetStudentInClass(userId, classId) {
      return exists(userPath(userId)) && profileInClass(get(userPath(userId)).data, classId);
    }

    function canReadFlag(flagData) {
      return isAdmin()
        || (
          isTeacher()
          && flagData.classIds is list
          && flagData.classIds.hasAny(userClassIds())
        );
    }

    function ownerScoreUpdateIsReasonable() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return (
        !changed.hasAny(["licenseId"])
        || resource.data.role == "teacher"
        || validStudentJoinClassUpdate()
      )
      && (
        !changed.hasAny(["xpTotal"])
        || (
          request.resource.data.xpTotal >= resource.data.xpTotal
          && request.resource.data.xpTotal <= resource.data.xpTotal + 1000
        )
      )
      && (
        !changed.hasAny(["activeEngagements"])
        || (
          request.resource.data.activeEngagements >= resource.data.activeEngagements
          && request.resource.data.activeEngagements <= resource.data.activeEngagements + 5
        )
      );
    }

    function validBaseUserCreate() {
      return request.resource.data.keys().hasOnly([
          "name",
          "role",
          "writtenProgress",
          "streak",
          "xpTotal",
          "activeEngagements",
          "createdAt",
          "lastUpdated",
          "classCode",
          "classId",
          "classIds",
          "classes",
          "licenseId",
          "joinCodeId",
          "accessCodeId",
          "signupInviteId",
          "accountManager",
          "schoolName"
        ])
        && request.resource.data.name is string
        && request.resource.data.writtenProgress is map
        && request.resource.data.streak is map
        && request.resource.data.streak.current == 0
        && request.resource.data.streak.longest == 0
        && request.resource.data.streak.lastDate == 0
        && request.resource.data.xpTotal == 0
        && request.resource.data.activeEngagements == 0
        && request.resource.data.createdAt is int
        && request.resource.data.lastUpdated is int;
    }

    function validStudentUserCreate() {
      return request.resource.data.role == "student"
        && request.resource.data.joinCodeId is string
        && validClassJoinCode(request.resource.data.joinCodeId)
        && validStudentApprovalForLicense(classJoinCodeData(request.resource.data.joinCodeId).licenseId)
        && request.resource.data.classCode is string
        && request.resource.data.classCode == classJoinCodeData(request.resource.data.joinCodeId).classId
        && request.resource.data.classId == request.resource.data.classCode
        && request.resource.data.classIds is list
        && request.resource.data.classIds.size() == 1
        && request.resource.data.classIds[0] == request.resource.data.classCode
        && request.resource.data.licenseId == classJoinCodeData(request.resource.data.joinCodeId).licenseId
        && request.resource.data.schoolName == classJoinCodeData(request.resource.data.joinCodeId).schoolName;
    }

    function validSoloUserCreate() {
      return request.resource.data.role == "solo"
        && !request.resource.data.keys().hasAny([
          "classCode",
          "classId",
          "classIds",
          "classes",
          "licenseId",
          "joinCodeId",
          "accessCodeId",
          "signupInviteId",
          "accountManager",
          "schoolName"
        ]);
    }

    function validLeadTeacherUserCreate() {
      return request.resource.data.role == "teacher"
        && validTeacherAccessCode(request.resource.data.accessCodeId)
        && request.resource.data.accountManager == true
        && request.resource.data.licenseId is string
        && request.resource.data.schoolName is string
        && request.resource.data.classCode is string
        && request.resource.data.classIds is list
        && request.resource.data.classIds.size() == 1
        && request.resource.data.classIds[0] == request.resource.data.classCode
        && request.resource.data.classes is list
        && request.resource.data.classes.size() == 1;
    }

    function validSharedTeacherUserCreate() {
      return request.resource.data.role == "teacher"
        && validTeacherClassInvite(request.resource.data.signupInviteId)
        && request.resource.data.accountManager == false
        && request.resource.data.classCode == ""
        && request.resource.data.schoolName is string;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && validBaseUserCreate()
        && (
          validStudentUserCreate()
          || validSoloUserCreate()
          || validLeadTeacherUserCreate()
          || validSharedTeacherUserCreate()
        );
      allow read: if canReadUserProfile(userId, resource.data);
      allow update: if isAdmin()
        || validTeacherRemoveStudentFromClass(userId)
        || (
          isOwner(userId)
          && request.resource.data.role == resource.data.role
          && ownerScoreUpdateIsReasonable()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "name",
            "classCode",
            "classId",
            "classIds",
            "classes",
            "licenseId",
            "joinCodeId",
            "schoolName",
            "writtenProgress",
            "streak",
            "xpTotal",
            "activeEngagements",
            "lastEngagementAt",
            "lastEngagementType",
            "lastEngagementMeta",
            "lastXP",
            "lastAcceptedInviteId",
            "lastUpdated"
          ])
          && ownerClassAccessUpdateAllowed()
        );
      allow delete: if false;

      match /progress/{cardId} {
        allow read: if canReadUserProgress(userId);
        allow write: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            "baseMastery",
            "consecutiveCorrect",
            "lastSeen",
            "status"
          ])
          && request.resource.data.baseMastery >= 0
          && request.resource.data.baseMastery <= 100
          && request.resource.data.consecutiveCorrect >= 0
          && request.resource.data.consecutiveCorrect <= 100
          && request.resource.data.lastSeen is int
          && request.resource.data.status in ["correct", "incorrect"];
      }
    }

    match /public_profiles/{userId} {
      allow read: if canReadPublicProfile(userId, resource.data);
      allow create, update: if isOwner(userId)
        && hasUserDocAfter()
        && request.resource.data.keys().hasOnly([
          "name",
          "role",
          "classId",
          "classIds",
          "xpTotal",
          "streak",
          "updatedAt"
        ])
        && request.resource.data.role in ["student", "solo", "teacher"]
        && request.resource.data.classIds is list
        && request.resource.data.xpTotal >= 0
        && request.resource.data.xpTotal <= userDataAfter().xpTotal + 1000
        && request.resource.data.streak.current >= 0
        && request.resource.data.streak.longest >= 0;
      allow update: if validTeacherPublicProfileClassRemoval(userId);
      allow delete: if isAdmin();
    }

    match /curriculums/{subjectId} {
      allow read: if signedIn();
      allow create, update: if isAdmin()
        && request.resource.data.subject is string
        && request.resource.data.chapters is list
        && request.resource.data.writtenQuestions is list;
      allow delete: if isAdmin();
    }

    match /flagged_content/{flagId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "anonymous",
          "contentId",
          "contentType",
          "subjectId",
          "classIds",
          "classLabels",
          "licenseId",
          "schoolName",
          "reporterRole",
          "comment",
          "status",
          "createdAt"
        ])
        && request.resource.data.anonymous == true
        && request.resource.data.status == "open"
        && request.resource.data.comment is string
        && request.resource.data.contentId is string
        && request.resource.data.subjectId is string
        && request.resource.data.classIds is list
        && request.resource.data.classLabels is list
        && request.resource.data.reporterRole in ["student", "solo", "teacher"];
      allow read: if canReadFlag(resource.data);
      allow update: if canReadFlag(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "reviewedBy",
          "reviewedAt",
          "adminNote"
        ]);
      allow delete: if isAdmin();
    }

    match /nudges/{nudgeId} {
      allow create: if isTeacherOrAdmin()
        && request.resource.data.keys().hasOnly([
          "targetUserId",
          "targetName",
          "classId",
          "className",
          "teacherId",
          "teacherName",
          "message",
          "reason",
          "assignmentIds",
          "status",
          "createdAt"
        ])
        && request.resource.data.targetUserId is string
        && request.resource.data.teacherId is string
        && request.resource.data.message is string
        && request.resource.data.assignmentIds is list
        && request.resource.data.status == "unread"
        && (
          isAdmin()
          || (
            request.resource.data.teacherId == emailId()
            && isTeacherForClass(request.resource.data.classId)
            && targetStudentInClass(
              request.resource.data.targetUserId,
              request.resource.data.classId
            )
          )
        );
      allow read: if isAdmin()
        || (isTeacher() && resource.data.teacherId == emailId())
        || (signedIn() && resource.data.targetUserId == emailId());
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.targetUserId == emailId()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "readAt"
          ])
          && request.resource.data.status in ["unread", "read"]
        );
      allow delete: if isAdmin();
    }

    match /class_join_codes/{codeId} {
      allow read: if isAdmin()
        || (
          signedIn()
          && resource.data.status == "active"
          && resource.data.expiresAt is timestamp
          && resource.data.expiresAt > request.time
        )
        || (
          isTeacher()
          && isTeacherForClass(resource.data.classId)
        );
      allow create: if isTeacher()
        && request.resource.data.keys().hasOnly([
          "code",
          "classId",
          "className",
          "licenseId",
          "schoolName",
          "createdBy",
          "createdByName",
          "status",
          "expiresAt",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.code == codeId
        && request.resource.data.classId is string
        && request.resource.data.className is string
        && request.resource.data.licenseId is string
        && request.resource.data.schoolName is string
        && request.resource.data.createdBy == emailId()
        && request.resource.data.createdByName is string
        && request.resource.data.status == "active"
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.createdAt is int
        && request.resource.data.updatedAt is int
        && isTeacherForClass(request.resource.data.classId)
        && licenseAllowsNewWork(request.resource.data.licenseId);
      allow update: if isAdmin()
        || (
          isTeacher()
          && isTeacherForClass(resource.data.classId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "status",
            "updatedAt"
          ])
          && request.resource.data.status in ["active", "revoked"]
          && request.resource.data.updatedAt is int
        );
      allow delete: if isAdmin();
    }

    match /class_invites/{inviteId} {
      allow create: if isTeacherOrAdmin()
        && request.resource.data.keys().hasOnly([
          "targetTeacherEmail",
          "invitedBy",
          "inviterName",
          "licenseId",
          "schoolName",
          "classId",
          "className",
          "classRecord",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.targetTeacherEmail is string
        && request.resource.data.invitedBy is string
        && request.resource.data.classId is string
        && request.resource.data.classRecord is map
        && request.resource.data.status == "pending"
        && (
          isAdmin()
          || (
            request.resource.data.invitedBy == emailId()
            && request.resource.data.licenseId is string
            && exists(licensePath(request.resource.data.licenseId))
            && canManageLicense(get(licensePath(request.resource.data.licenseId)).data)
            && isTeacherForClass(request.resource.data.classId)
          )
        );
      allow read: if isAdmin()
        || resource.data.invitedBy == emailId()
        || resource.data.targetTeacherEmail == emailId();
      allow update: if isAdmin()
        || (
          hasRole("teacher")
          && resource.data.status == "pending"
          && resource.data.targetTeacherEmail == emailId()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "acceptedAt",
            "acceptedBy",
            "updatedAt"
          ])
          && request.resource.data.status in ["accepted", "declined"]
          && request.resource.data.acceptedBy == emailId()
          && (
            request.resource.data.status == "declined"
            || (
              hasUserDocAfter()
              && userDataAfter().role == "teacher"
              && userDataAfter().licenseId == resource.data.licenseId
              && userDataAfter().lastAcceptedInviteId == inviteId
              && userDataAfter().classIds is list
              && listContains(userDataAfter().classIds, resource.data.classId)
            )
          )
        );
      allow delete: if isAdmin()
        || (
          resource.data.invitedBy == emailId()
          && resource.data.status == "pending"
        );
    }

    match /teacher_access_codes/{codeId} {
      allow read: if isAdmin()
        || (
          signedIn()
          && resource.data.targetTeacherEmail == emailId()
          && resource.data.status == "active"
        );
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "targetTeacherEmail",
          "schoolName",
          "subjectIds",
          "licenseId",
          "maxClasses",
          "maxSeatsPerClass",
          "maxStudentSeats",
          "trialDays",
          "status",
          "expiresAt",
          "createdAt",
          "createdBy",
          "note"
        ])
        && request.resource.data.targetTeacherEmail is string
        && request.resource.data.schoolName is string
        && request.resource.data.subjectIds is list
        && request.resource.data.licenseId is string
        && request.resource.data.maxClasses is int
        && request.resource.data.maxSeatsPerClass is int
        && request.resource.data.trialDays is int
        && request.resource.data.status == "active"
        && request.resource.data.expiresAt is timestamp;
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.targetTeacherEmail == emailId()
          && resource.data.status == "active"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "redeemedAt",
            "redeemedBy",
            "licenseId",
            "updatedAt"
          ])
          && request.resource.data.status == "redeemed"
          && request.resource.data.redeemedBy == emailId()
          && request.resource.data.redeemedAt is timestamp
        );
      allow delete: if isAdmin();
    }

    match /licenses/{licenseId} {
      allow read: if isLicenseMember(licenseId, resource.data);
      allow create: if (isAdmin() || teacherCanCreatePilotLicense(licenseId))
        && request.resource.data.school_name is string
        && request.resource.data.unlocked_subjects is list
        && request.resource.data.max_classes is int
        && request.resource.data.max_seats_per_class is int
        && (
          !request.resource.data.keys().hasAny(["max_student_seats"])
          || request.resource.data.max_student_seats is int
        )
        && request.resource.data.keys().hasOnly([
          "school_name",
          "unlocked_subjects",
          "max_classes",
          "max_seats_per_class",
          "max_student_seats",
          "ownerId",
          "teacherIds",
          "adminIds",
          "classes",
          "status",
          "trialStartsAt",
          "trialEndsAt",
          "expiresAt",
          "createdFromAccessCodeId",
          "createdAt",
          "updatedAt"
        ]);
      allow update: if isAdmin()
        || (
          canManageLicense(resource.data)
          && licenseIsOpen(resource.data)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "classes",
            "teacherIds",
            "updatedAt"
          ])
        );
      allow delete: if isAdmin();

      match /approved_students/{studentId} {
        allow read: if isAdmin()
          || canManageLicense(get(licensePath(licenseId)).data)
          || (
            signedIn()
            && studentId == emailId()
            && resource.data.email == emailId()
          );
        allow create, update: if canManageLicense(get(licensePath(licenseId)).data)
          && licenseIsOpen(get(licensePath(licenseId)).data)
          && request.resource.data.keys().hasOnly([
            "email",
            "displayName",
            "licenseId",
            "schoolName",
            "status",
            "createdAt",
            "createdBy",
            "updatedAt",
            "updatedBy",
            "revokedAt",
            "revokedBy"
          ])
          && request.resource.data.email == studentId
          && request.resource.data.licenseId == licenseId
          && request.resource.data.status in ["approved", "revoked"]
          && request.resource.data.createdAt is int
          && request.resource.data.createdBy is string
          && request.resource.data.updatedAt is int
          && request.resource.data.updatedBy == emailId();
        allow update: if signedIn()
          && studentId == emailId()
          && resource.data.email == emailId()
          && resource.data.licenseId == licenseId
          && resource.data.status in ["approved", "joined"]
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "claimedBy",
            "claimedAt",
            "joinedClassIds",
            "updatedAt",
            "updatedBy"
          ])
          && request.resource.data.status == "joined"
          && request.resource.data.claimedBy == emailId()
          && request.resource.data.claimedAt is timestamp
          && request.resource.data.joinedClassIds is list
          && request.resource.data.updatedAt is int
          && request.resource.data.updatedBy == emailId();
        allow delete: if isAdmin()
          || canManageLicense(get(licensePath(licenseId)).data);
      }
    }

    match /assignments/{assignmentId} {
      allow read: if signedIn() && canReadAssignment(resource.data);
      allow create: if isTeacher()
        && request.resource.data.teacherId == emailId()
        && isTeacherForClass(request.resource.data.classId)
        && request.resource.data.classId is string
        && request.resource.data.targetType in ["chapter", "subsection", "essay"]
        && request.resource.data.targetId is string
        && request.resource.data.status == "active"
        && request.resource.data.completedBy is map
        && licenseAllowsNewWork(request.resource.data.licenseId)
        && request.resource.data.keys().hasOnly([
          "teacherId",
          "classId",
          "className",
          "licenseId",
          "subjectId",
          "targetType",
          "targetId",
          "targetLabel",
          "deadline",
          "targetMastery",
          "status",
          "completedBy",
          "createdAt",
          "updatedAt"
        ]);
      allow update: if isAdmin()
        || (
          isTeacher()
          && resource.data.teacherId == emailId()
          && isTeacherForClass(resource.data.classId)
          && request.resource.data.status in ["active", "cancelled"]
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "deadline",
            "targetMastery",
            "status",
            "targetLabel",
            "className",
            "updatedAt"
          ])
        );
      allow delete: if false;

      match /completions/{studentId} {
        allow read: if signedIn()
          && (
            isAdmin()
            || (isTeacher() && assignmentData(assignmentId).teacherId == emailId())
            || isOwner(studentId)
          );
        allow create, update: if isOwner(studentId)
          && assignmentData(assignmentId).status == "active"
          && isClassMember(assignmentData(assignmentId).classId)
          && request.resource.data.userId == studentId
          && request.resource.data.classId == assignmentData(assignmentId).classId
          && request.resource.data.status == "complete"
          && request.resource.data.mastery >= assignmentData(assignmentId).targetMastery
          && request.resource.data.mastery <= 100
          && request.resource.data.keys().hasOnly([
            "userId",
            "userName",
            "classId",
            "className",
            "mastery",
            "targetMastery",
            "completedAt",
            "status"
          ]);
        allow delete: if isAdmin();
      }
    }
  }
}
